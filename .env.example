# API Keys and Environment Variables
# Copy this file to .env and fill in your actual credentials

# Google Sheets API
# Note: Also need credentials.json and token.json from Google Cloud Console
# Download credentials.json from: https://console.cloud.google.com/apis/credentials
# The token.json will be auto-generated on first run via OAuth flow
GOOGLE_API_KEY=your_google_api_key_here

# Example API keys (add yours as needed)
# OPENAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram - Trade Insightfully bot (all floor alerts)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Telegram - OF_Bot (high-conviction alerts only: qty>2000 + very bullish)
OF_BOT_TOKEN=your_of_bot_token_here
OF_BOT_CHAT_ID=your_chat_id_here
